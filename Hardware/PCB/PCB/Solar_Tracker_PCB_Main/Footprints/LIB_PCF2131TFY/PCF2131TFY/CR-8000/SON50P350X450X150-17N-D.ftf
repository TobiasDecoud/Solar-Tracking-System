                    (vertex
                      (pt -175000 -225000
                        (width 10000)
                      )
                      (pt -175000 225000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -175000 137500
                        (width 10000)
                      )
                      (pt -87500 225000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CW
                        (r 12500)
                        (begin
                          (pt -215000 252500
                            (width 25000)
                          )
                        )
                        (center 0 0)
                        (end
                          (pt -215000 252500
                            (width 25000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
           ); End of layout
         ); End of heelprint
         (toeprint
