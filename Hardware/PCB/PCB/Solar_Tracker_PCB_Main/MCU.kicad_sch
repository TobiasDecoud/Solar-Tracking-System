	(text_box "Segun \"I2C-bus specification and user manual\"\ntr = 1000ns (Standard-mode, Page 44)\nRpmax = tr/(0.8473*Cb) (Page 50)\nRpmin = (VDD - VOL)/IOL (Page 51)\nIOL = 3mA (Page 51)\nVOL = 0.32V (Datasheet OPR3001-Q1, Page 6)"
		(exclude_from_sim no)
		(at 179.07 144.78 0)
		(size 52.07 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "45ab4716-1d98-4a73-8feb-5719b098648d")
	)
	(text_box "The recommended setting for the RC delay circuit is usually R=10kΩ and C=1µF. Page 42\n\nCapacitors X7R/X5R"
		(exclude_from_sim no)
		(at 12.7 44.45 0)
		(size 53.34 11.43)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b3d46cf5-4b68-429f-ba22-60d57ad1f7b1")
	)
	(text_box "Decoupling VDD hacia placa secundaria\nSe colocan capacitores en paralelo de distinto valor para cubrir diferentes rangos de frecuencia:\n - 10 µF: reserva de energía, estabiliza variaciones lentas de carga.\n - 100 nF: filtra transitorios rápidos y ruido de alta frecuencia.\nEsta combinación asegura que la línea de 3V3 llegue limpia y estable a la placa secundaria."
		(exclude_from_sim no)
		(at 179.024 133.1261 0)
		(size 105.456 11.6539)
		(margins 0.9525 0.9525 0.9525 0.9525)
