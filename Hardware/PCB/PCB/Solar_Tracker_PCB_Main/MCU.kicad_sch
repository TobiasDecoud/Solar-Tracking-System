	(text "Connect VOUT to the VDD plane for heat dissipation. Page 3\n\n"
		(exclude_from_sim no)
		(at 231.648 46.99 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0637e863-1e16-4852-9ce0-226906c82461")
	)
	(text_box "Output capacitor must be tantalum type with ESR between 0.3 Ω and 22 Ω for regulator stability. Input capacitor of 10 µF tantalum is also recommended. Page 15\n"
		(exclude_from_sim no)
		(at 179.07 88.9 0)
		(size 105.41 6.35)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "2229bf65-563b-49c0-b771-79e2daa7f563")
	)
	(text_box "Decidí usar 4,7k. Si utilizamos cable UTP cat5 o cat6 estamos bastante lejos de la Rpmax, y nos da la posibilidad (mas rango) de usar otros tipos de cables (con mas capacitancia) de ser necesario.\nRpmin no depende de la capacitancia, por lo que siempre será 1k, 4.7k esta alejado de forma segura de la Rmin.\n"
		(exclude_from_sim no)
		(at 231.14 144.78 0)
		(size 53.34 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "3b1e97d3-cb9c-414f-b968-86f080756125")
	)
	(text_box "Segun \"I2C-bus specification and user manual\"\ntr = 1000ns (Standard-mode, Page 44)\nRpmax = tr/(0.8473*Cb) (Page 50)\nRpmin = (VDD - VOL)/IOL (Page 51)\nIOL = 3mA (Page 51)\nVOL = 0.32V (Datasheet OPR3001-Q1, Page 6)"
		(exclude_from_sim no)
		(at 179.07 144.78 0)
		(size 52.07 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "45ab4716-1d98-4a73-8feb-5719b098648d")
	)
	(text_box "The recommended setting for the RC delay circuit is usually R=10kΩ and C=1µF. Page 42\n"
		(exclude_from_sim no)
		(at 12.7 44.45 0)
		(size 53.34 11.43)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b3d46cf5-4b68-429f-ba22-60d57ad1f7b1")
	)
